{
  "$schema": "https://notiving.dev/design-tokens.schema.json",
  "meta": {
    "version": "0.1.0",
    "description": "Notiving Design System — Clean minimal with warm orange accents"
  },

  "color": {
    "primitive": {
      "orange": {
        "50":  "#fff7ed",
        "100": "#ffedd5",
        "200": "#fed7aa",
        "300": "#fdba74",
        "400": "#fb923c",
        "500": "#f97316",
        "600": "#ea580c",
        "700": "#c2410c",
        "800": "#9a3412",
        "900": "#7c2d12",
        "950": "#431407"
      },
      "gray": {
        "50":  "#fafafa",
        "100": "#f5f5f5",
        "200": "#e5e5e5",
        "300": "#d4d4d4",
        "400": "#a3a3a3",
        "500": "#737373",
        "600": "#525252",
        "700": "#404040",
        "800": "#262626",
        "900": "#171717",
        "950": "#0a0a0a"
      },
      "white": "#ffffff",
      "black": "#000000",
      "red": {
        "500": "#ef4444",
        "600": "#dc2626"
      },
      "green": {
        "500": "#22c55e",
        "600": "#16a34a"
      },
      "yellow": {
        "500": "#eab308",
        "600": "#ca8a04"
      }
    },

    "semantic": {
      "light": {
        "background":           { "$value": "{color.primitive.white}" },
        "background-secondary": { "$value": "{color.primitive.gray.50}" },
        "background-tertiary":  { "$value": "{color.primitive.gray.100}" },
        "foreground":           { "$value": "{color.primitive.gray.900}" },
        "foreground-secondary": { "$value": "{color.primitive.gray.600}" },
        "foreground-tertiary":  { "$value": "{color.primitive.gray.400}" },
        "border":               { "$value": "{color.primitive.gray.200}" },
        "border-secondary":     { "$value": "{color.primitive.gray.100}" },
        "ring":                 { "$value": "{color.primitive.orange.500}" },
        "primary":              { "$value": "{color.primitive.orange.500}" },
        "primary-hover":        { "$value": "{color.primitive.orange.600}" },
        "primary-active":       { "$value": "{color.primitive.orange.700}" },
        "primary-foreground":   { "$value": "{color.primitive.white}" },
        "primary-muted":        { "$value": "{color.primitive.orange.50}" },
        "destructive":          { "$value": "{color.primitive.red.500}" },
        "destructive-foreground": { "$value": "{color.primitive.white}" },
        "success":              { "$value": "{color.primitive.green.500}" },
        "success-foreground":   { "$value": "{color.primitive.white}" },
        "warning":              { "$value": "{color.primitive.yellow.500}" },
        "warning-foreground":   { "$value": "{color.primitive.gray.900}" },
        "overlay":              "rgba(0, 0, 0, 0.4)"
      },
      "dark": {
        "background":           { "$value": "{color.primitive.gray.950}" },
        "background-secondary": { "$value": "{color.primitive.gray.900}" },
        "background-tertiary":  { "$value": "{color.primitive.gray.800}" },
        "foreground":           { "$value": "{color.primitive.gray.50}" },
        "foreground-secondary": { "$value": "{color.primitive.gray.400}" },
        "foreground-tertiary":  { "$value": "{color.primitive.gray.600}" },
        "border":               { "$value": "{color.primitive.gray.800}" },
        "border-secondary":     { "$value": "{color.primitive.gray.700}" },
        "ring":                 { "$value": "{color.primitive.orange.500}" },
        "primary":              { "$value": "{color.primitive.orange.500}" },
        "primary-hover":        { "$value": "{color.primitive.orange.400}" },
        "primary-active":       { "$value": "{color.primitive.orange.300}" },
        "primary-foreground":   { "$value": "{color.primitive.white}" },
        "primary-muted":        { "$value": "{color.primitive.orange.950}" },
        "destructive":          { "$value": "{color.primitive.red.600}" },
        "destructive-foreground": { "$value": "{color.primitive.white}" },
        "success":              { "$value": "{color.primitive.green.600}" },
        "success-foreground":   { "$value": "{color.primitive.white}" },
        "warning":              { "$value": "{color.primitive.yellow.600}" },
        "warning-foreground":   { "$value": "{color.primitive.gray.50}" },
        "overlay":              "rgba(0, 0, 0, 0.6)"
      }
    }
  },

  "font": {
    "family": {
      "sans": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji'",
      "mono": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace"
    },
    "size": {
      "xs":   { "value": 12, "unit": "px", "lineHeight": 16 },
      "sm":   { "value": 14, "unit": "px", "lineHeight": 20 },
      "base": { "value": 16, "unit": "px", "lineHeight": 24 },
      "lg":   { "value": 18, "unit": "px", "lineHeight": 28 },
      "xl":   { "value": 20, "unit": "px", "lineHeight": 28 },
      "2xl":  { "value": 24, "unit": "px", "lineHeight": 32 },
      "3xl":  { "value": 30, "unit": "px", "lineHeight": 36 },
      "4xl":  { "value": 36, "unit": "px", "lineHeight": 40 }
    },
    "weight": {
      "normal":   400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    }
  },

  "spacing": {
    "0":    0,
    "0.5":  2,
    "1":    4,
    "1.5":  6,
    "2":    8,
    "2.5":  10,
    "3":    12,
    "4":    16,
    "5":    20,
    "6":    24,
    "8":    32,
    "10":   40,
    "12":   48,
    "16":   64,
    "20":   80,
    "24":   96
  },

  "radius": {
    "none": 0,
    "sm":   4,
    "md":   8,
    "lg":   12,
    "xl":   16,
    "2xl":  24,
    "full": 9999
  },

  "shadow": {
    "sm":  "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md":  "0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.07)",
    "lg":  "0 10px 15px -3px rgba(0, 0, 0, 0.07), 0 4px 6px -4px rgba(0, 0, 0, 0.07)",
    "xl":  "0 20px 25px -5px rgba(0, 0, 0, 0.07), 0 8px 10px -6px rgba(0, 0, 0, 0.07)"
  },

  "duration": {
    "fast":    "100ms",
    "normal":  "200ms",
    "slow":    "300ms"
  },

  "easing": {
    "default": "cubic-bezier(0.4, 0, 0.2, 1)",
    "in":      "cubic-bezier(0.4, 0, 1, 1)",
    "out":     "cubic-bezier(0, 0, 0.2, 1)",
    "in-out":  "cubic-bezier(0.4, 0, 0.2, 1)"
  },

  "breakpoint": {
    "sm":  640,
    "md":  768,
    "lg":  1024,
    "xl":  1280,
    "2xl": 1536
  }
}
