{
  "name": "notiving",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy:api": "pnpm --filter @notiving/api run deploy",
    "deploy:web": "vercel link --project notiving-web --yes && vercel deploy --prod --yes --archive=tgz",
    "deploy:h5": "vercel link --project notiving-h5 --yes && vercel deploy --prod --yes --archive=tgz",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
